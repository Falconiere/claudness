{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "bun-types"],
    "allowImportingTsExtensions": true
  },
  "include": ["pi/**/*.ts"],
  "exclude": ["node_modules", "**/node_modules/**"]
}
