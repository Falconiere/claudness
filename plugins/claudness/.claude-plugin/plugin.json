{
  "name": "claudness",
  "version": "1.2.0",
  "description": "Falconiere's personal Claude Code bundle: skills, agents, slash commands, and hooks.",
  "author": {
    "name": "Falconiere Barbosa",
    "email": "hello@falconiere.io"
  },
  "homepage": "https://github.com/falconiere/claudness",
  "repository": "https://github.com/falconiere/claudness.git",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "skills",
    "agents",
    "hooks",
    "caveman"
  ],
  "requires": [
    {
      "plugin": "code-simplifier@claude-plugins-official",
      "marketplace": "claude-plugins-official",
      "source": { "source": "github", "repo": "anthropics/claude-plugins-official" },
      "reason": "review-and-commit / push-review / address-pr-comments delegate simplification to the code-simplifier subagent"
    },
    {
      "plugin": "caveman@caveman",
      "marketplace": "caveman",
      "source": { "source": "github", "repo": "JuliusBrussee/caveman" },
      "reason": "review pipelines delegate diff review to caveman:cavecrew-reviewer"
    }
  ]
}
